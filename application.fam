enable_logs = 0
enable_deep_diagnostics = 0
enable_typing_actions = 1
enable_bluetooth_output = 1
enable_keyboard_layout = 1
enable_debug_unlock_hook = 0
enable_app_rpc = 0
stack_size_kib = 8

common_cdefines = [
    "APP_FlipPass",
    f"FLIPPASS_ENABLE_LOGS={enable_logs}",
    "FLIPPASS_ENABLE_SYSTEM_TRACE_CAPTURE=0",
    "FLIPPASS_ENABLE_GZIP_PAGED_TRACE=0",
    "FLIPPASS_ENABLE_PARSER_FURI_TRACE=0",
    "FLIPPASS_ENABLE_VERBOSE_UNLOCK_LOG=0",
    f"FLIPPASS_ENABLE_DEEP_DIAGNOSTICS={enable_deep_diagnostics}",
    "FLIPPASS_ENABLE_XML_PREFLIGHT=0",
    f"FLIPPASS_ENABLE_TYPING_ACTIONS={enable_typing_actions}",
    f"FLIPPASS_ENABLE_BLUETOOTH_OUTPUT={enable_bluetooth_output}",
    f"FLIPPASS_ENABLE_KEYBOARD_LAYOUT={enable_keyboard_layout}",
    f"FLIPPASS_ENABLE_DEBUG_UNLOCK_HOOK={enable_debug_unlock_hook}",
    f"FLIPPASS_ENABLE_APP_RPC={enable_app_rpc}",
]

App(
    appid="flippass",
    name="FlipPass",
    apptype=FlipperAppType.EXTERNAL,
    entry_point="flippass_app",
    fap_version="1.1",
    fap_author="Arckanos",
    fap_description="KeePass KDBX 4 vault browser with USB and Bluetooth HID typing.",
    fap_weburl="https://github.com/Arckanos/FlipPass",
    requires=[
        "gui",
    ],
    cdefines=common_cdefines,
    fap_icon="icons/icon.png",
    fap_icon_assets="icons",
    fap_category="Tools",
    stack_size=stack_size_kib * 1024,
    order=90,
    sources=[
        "FlipPass.c",
        "flippass_db_host.c",
        "flippass_modules.c",
        "flippass_open.c",
        "flippass_rpc.c",
        "scenes/flippass_scene.c",
        "scenes/flippass_db_browser_view.c",
        "scenes/flippass_progress_view.c",
        "scenes/flippass_scene_db_entries.c",
        "scenes/flippass_scene_file_browser.c",
        "scenes/flippass_scene_other_field_actions.c",
        "scenes/flippass_scene_other_fields.c",
        "scenes/flippass_scene_password_entry.c",
        "scenes/flippass_scene_status.c",
        "scenes/flippass_scene_text_view.c",
        "scenes/flippass_scene_vault_fallback.c",
        "kdbx/hmac.c",
        "kdbx/kdbx_arena.c",
        "kdbx/kdbx_data.c",
        "kdbx/kdbx_open_profile.c",
        "kdbx/kdbx_protected.c",
        "kdbx/kdbx_vault.c",
        "kdbx/memzero.c",
        "kdbx/sha2.c",
        "mntminput/text_input.c",
        "mntminput/validators.c",
    ]
    + (["scenes/flippass_scene_keyboard_layout.c"] if enable_keyboard_layout else ["scenes/flippass_scene_keyboard_layout_stub.c"])
    + (["scenes/flippass_scene_send_confirm.c"] if enable_typing_actions else ["scenes/flippass_scene_send_confirm_stub.c"])
    + (
        ["transport/flippass_output.c", "transport/flippass_output_transport_plugins.c"]
        if enable_typing_actions
        else ["transport/flippass_output_stub.c"]
    ),
)

if enable_typing_actions:
    App(
        appid="flippass_output_usb",
        apptype=FlipperAppType.PLUGIN,
        entry_point="flippass_output_usb_plugin_ep",
        requires=["flippass"],
        fal_embedded=True,
        sources=["plugins/flippass_output_usb_plugin.c"],
    )

    App(
        appid="flippass_output_ble",
        apptype=FlipperAppType.PLUGIN,
        entry_point="flippass_output_ble_plugin_ep",
        requires=["flippass"],
        fal_embedded=True,
        fap_libs=(["ble_profile"] if enable_bluetooth_output else []),
        sources=["plugins/flippass_output_ble_plugin.c"],
    )

if enable_app_rpc:
    App(
        appid="flippass_rpc_commands",
        apptype=FlipperAppType.PLUGIN,
        entry_point="flippass_rpc_commands_plugin_ep",
        requires=["flippass"],
        fal_embedded=True,
        sources=["plugins/flippass_rpc_commands_plugin.c"],
    )

App(
    appid="flippass_open_acquire",
    apptype=FlipperAppType.PLUGIN,
    entry_point="flippass_open_acquire_plugin_ep",
    requires=["flippass"],
    fal_embedded=True,
    cdefines=common_cdefines,
    sources=[
        "plugins/flippass_open_acquire_plugin.c",
        "kdbx/aescrypt.c",
        "kdbx/aeskey.c",
        "kdbx/aestab.c",
        "kdbx/kdbx_open_profile.c",
        "kdbx/kdbx_parser.c",
        "kdbx/memzero.c",
        "kdbx/sha2.c",
    ],
)

App(
    appid="flippass_open_stream",
    apptype=FlipperAppType.PLUGIN,
    entry_point="flippass_open_stream_plugin_ep",
    requires=["flippass"],
    fal_embedded=True,
    cdefines=common_cdefines,
    sources=[
        "plugins/flippass_open_stream_plugin.c",
        "kdbx/kdbx_open_profile.c",
        "kdbx/kdbx_open_outer_payload.c",
        "kdbx/kdbx_protected.c",
        "kdbx/sha2.c",
        "kdbx/hmac.c",
        "kdbx/aescrypt.c",
        "kdbx/aeskey.c",
        "kdbx/aestab.c",
        "kdbx/aes_modes.c",
        "kdbx/memzero.c",
    ]
)

App(
    appid="flippass_open_inflate_nonpaged",
    apptype=FlipperAppType.PLUGIN,
    entry_point="flippass_open_inflate_nonpaged_plugin_ep",
    requires=["flippass"],
    fal_embedded=True,
    cdefines=common_cdefines,
    sources=[
        "plugins/flippass_open_inflate_nonpaged_plugin.c",
        "kdbx/miniz_tinfl.c",
        "kdbx/memzero.c",
    ],
)

App(
    appid="flippass_open_inflate_paged",
    apptype=FlipperAppType.PLUGIN,
    entry_point="flippass_open_inflate_paged_plugin_ep",
    requires=["flippass"],
    fal_embedded=True,
    cdefines=common_cdefines,
    sources=[
        "plugins/flippass_open_inflate_paged_plugin.c",
        "kdbx/kdbx_protected.c",
        "kdbx/miniz_tinfl_paged.c",
        "kdbx/sha2.c",
        "kdbx/hmac.c",
        "kdbx/memzero.c",
    ],
)

App(
    appid="flippass_open_model",
    apptype=FlipperAppType.PLUGIN,
    entry_point="flippass_open_model_plugin_ep",
    requires=["flippass"],
    fal_embedded=True,
    cdefines=common_cdefines,
    sources=[
        "plugins/flippass_open_model_plugin.c",
        "kdbx/kdbx_protected.c",
        "kdbx/memzero.c",
        "kdbx/sha2.c",
        "kdbx/xml_parser.c",
    ],
)

if enable_typing_actions and enable_keyboard_layout:
    App(
        appid="flippass_keyboard_layout",
        apptype=FlipperAppType.PLUGIN,
        entry_point="flippass_keyboard_layout_plugin_ep",
        requires=["flippass"],
        fal_embedded=True,
        sources=["plugins/flippass_keyboard_layout_plugin.c"],
    )
